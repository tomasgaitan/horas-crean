# URL del Web App de Google Apps Script (termina en /exec).
# Es el backend que lee/escribe la planilla. Requerido para que la app funcione.
VITE_APPS_SCRIPT_URL=

# PIN inicial para acceder a la pantalla de administración (alta de profesionales).
# Seguridad liviana de kiosco — no es criptográfica. Si se deja vacío, usa el default del código.
VITE_DEFAULT_PIN=
